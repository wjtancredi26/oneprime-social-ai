generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
  CLIENT
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model Company {
  id Int @id @default(autoincrement())

  name      String
  cnpj      String? @unique
  segment   String?
  logoUrl   String?
  whatsapp  String?
  instagram String?
  facebook  String?
  website   String?
  tone      String?
  colors    String?
  products  String? @db.Text
  brands    String? @db.Text
  ctas      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  posts             ScheduledPost[]
  socialConnections SocialConnection[]
  invitations       UserInvitation[]
  metaOAuthSessions  MetaOAuthSession[]

  @@index([name])
}

model User {
  id Int @id @default(autoincrement())

  name     String
  email    String @unique
  password String?

  role   UserRole   @default(CLIENT)
  status UserStatus @default(ACTIVE)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  posts               ScheduledPost[]
  passwordResetTokens PasswordResetToken[]

  invitationsSent UserInvitation[] @relation("InvitationSender")
  metaOAuthSessions MetaOAuthSession[]

  @@index([companyId])
  @@index([role])
  @@index([status])
  @@index([companyId, status])
}

model UserInvitation {
  id Int @id @default(autoincrement())

  name      String
  email     String
  role      UserRole
  tokenHash String   @unique

  expiresAt DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invitedById Int
  invitedBy   User @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([companyId])
  @@index([invitedById])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@unique([companyId, email])
}

model ScheduledPost {
  id Int @id @default(autoincrement())

  title     String?
  prompt    String
  caption   String @db.Text
  hashtags  String @db.Text
  imageIdea String @db.Text
  cta       String @db.Text
  imageUrl  String?

  network     String
  scheduledAt DateTime
  status      String   @default("AGENDADO")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publishedAt DateTime?
  attempts    Int      @default(0)
  lastError   String?  @db.Text

  facebookPostId  String?
  instagramPostId String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([scheduledAt])
}


model MetaOAuthSession {
  id Int @id @default(autoincrement())

  tokenHash        String   @unique
  payloadEncrypted String   @db.Text
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
}

model SocialConnection {
  id        Int    @id @default(autoincrement())
  companyId Int
  provider  String @default("META")

  facebookPageId    String
  facebookPageName  String
  instagramUserId   String?
  instagramUsername String?

  pageAccessTokenEncrypted String    @db.Text
  userAccessTokenEncrypted String?   @db.Text
  tokenExpiresAt           DateTime?

  status      String   @default("CONNECTED")
  lastError   String?  @db.Text
  connectedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([companyId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}