generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id         Int      @id @default(autoincrement())

  name       String
  cnpj       String?  @unique
  segment    String?
  logoUrl    String?
  whatsapp   String?
  instagram  String?
  facebook   String?
  website    String?
  tone       String?
  colors     String?
  products   String?  @db.Text
  brands     String?  @db.Text
  ctas       String?  @db.Text

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  users User[]
  posts ScheduledPost[]
}

model User {
  id         Int      @id @default(autoincrement())

  name       String
  email      String   @unique
  password   String
  role       String   @default("USER")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  companyId  Int?
  company    Company? @relation(fields: [companyId], references: [id])

  posts ScheduledPost[]
}

model ScheduledPost {
  id           Int      @id @default(autoincrement())

  title        String?
  prompt       String
  caption      String   @db.Text
  hashtags     String   @db.Text
  imageIdea    String   @db.Text
  cta          String   @db.Text
  imageUrl     String?

  network      String
  scheduledAt  DateTime
  status       String   @default("AGENDADO")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  // Scheduler
  publishedAt      DateTime?
  attempts         Int      @default(0)
  lastError        String?  @db.Text

  // IDs das redes sociais
  facebookPostId   String?
  instagramPostId  String?

  userId       Int
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId    Int?
  company      Company? @relation(fields: [companyId], references: [id])
}